library ieee;
  use ieee.std_logic_1164.all;
  use work.myTypes.all;
  use ieee.numeric_std.all;

entity dlx_cu is
  generic (
    MICROCODE_MEM_SIZE : integer := 62; -- Microcode Memory Size. Included all Instructions DLX will be able to execute and not.
    FUNC_SIZE          : integer := 11; -- Func Field Size for R-Type Ops
    OP_CODE_SIZE       : integer := 6;  -- Op Code Size
    IR_SIZE            : integer := 32; -- Instruction Register Size
    CW_SIZE            : integer := 18  -- Control Word Size. Added new Control Signals.
  );
  port (
    Clk  : in    std_logic; -- Clock
    nRst : in    std_logic; -- Reset:Active-Low

    -- Instruction Register
    IR_IN : in    std_logic_vector(IR_SIZE - 1 downto 0);

    -- Debug Signals
    DBG_CW_OUT : out   std_logic_vector(CW_SIZE - 1 downto 0);

    -- IF Control Signal - STAGE 1
    IR_LATCH_EN  : out   std_logic; -- Instruction Register Latch Enable
    NPC_LATCH_EN : out   std_logic; -- NextProgramCounter Register Latch Enable

    -- ID Control Signals - STAGE 2
    RegA_LATCH_EN : out   std_logic; -- Register A Latch Enable
    -- RegB_LATCH_EN      : out std_logic;  -- Register B Latch Enable
    SIGN_UNSIGN_EN  : out   std_logic; -- Control Signal for performing signed ('1') or unsigned ('0') extensions.
    RegIMM_LATCH_EN : out   std_logic; -- Immediate Register Latch Enable
    JAL_EN          : out   std_logic; -- Control Signal for Jump and Link Instruction

    -- EX Control Signals - STAGE 3
    MUXA_SEL      : out   std_logic; -- MUX-A Sel
    MUXB_SEL      : out   std_logic; -- MUX-B Sel
    ALU_OUTREG_EN : out   std_logic; -- ALU Output Register Enable
    EQ_COND       : out   std_logic; -- Branch if (not) Equal to Zero
    JMP           : out   std_logic; -- Control Signal for unconditional Jump Instructions.
    EQZ_NEQZ      : out   std_logic; -- Control Signal for bnez Instruction ('0') and beqz Instruction ('1').

    -- ALU Operation Code
    ALU_OPCODE : out   aluOp; -- choose between implicit or exlicit coding, like std_logic_vector(ALU_OPC_SIZE -1 downto 0);

    -- MEM Control Signals - STAGE 4
    DRAM_WE      : out   std_logic; -- Data RAM Write Enable
    LMD_LATCH_EN : out   std_logic; -- LMD Register Latch Enable
    JUMP_EN      : out   std_logic; -- JUMP Enable Signal for PC input MUX
    PC_LATCH_EN  : out   std_logic; -- Program Counte Latch Enable

    -- WB Control signals - STAGE 5
    WB_MUX_SEL : out   std_logic; -- Write Back MUX Sel
    RF_WE      : out   std_logic  -- Register File Write Enable
  );
end entity dlx_cu;

architecture dlx_cu_hw of dlx_cu is

  type mem_array is array (integer range 0 to MICROCODE_MEM_SIZE - 1) of std_logic_vector(CW_SIZE - 1 downto 0);
  --  STAGE: 1    2    3      4  5
  --        00 0000 000000 0000 00
  signal cw_mem : mem_array := ("101000101000000111",  -- R type (0x00) ***
                                "000000000000000000",  -- ??? (0x01)
                                "110010011110001100",  -- J (0X02) ***
                                "110011011110001101",  -- JAL (0x03) ***
                                "111110011101001100",  -- BEQZ (0x04) ***
                                "111110011100001100",  -- BNEZ (0x05) ***
                                "000000000000000000",  -- BFPT (0x06)
                                "000000000000000000",  -- BFPF (0x07)
                                "101110111000000111",  -- ADD i (0X08) ***
                                "101010111000000111",  -- ADDUI (0X09) @@@
                                "101110111000000111",  -- SUBI (0X0A) ***
                                "101010111000000111",  -- SUBUI (0X0B) @@@
                                "101110111000000111",  -- ANDI (0X0C) ***
                                "101110111000000111",  -- ORI (0X0D) ***
                                "101110111000000111",  -- XORI (0X0E) ***
                                "000000000000000000",  -- LHI (0X0F)
                                "000000000000000000",  -- RFE (0X10)
                                "000000000000000000",  -- TRAP (0X11)
                                "000000000000000000",  -- JR (0X12)
                                "000000000000000000",  -- JALR (0X13)
                                "101110111000000111",  -- SLLI (0X14) ***
                                "100000000000000100",  -- NOP (0X15) ***
                                "101110111000000111",  -- SRLI (0X16) ***
                                "101110111000000111",  -- SRAI (0X17) @@@
                                "101110111000000111",  -- SEQI (0X18) @@@
                                "101110111000000111",  -- SNEI (0X19) ***
                                "101110111000000111",  -- SLTI (0X1A) @@@
                                "101110111000000111",  -- SGTI (0X1B) @@@
                                "101110111000000111",  -- SLEI (0X1C) ***
                                "101110111000000111",  -- SGEI (0X1D) ***
                                "000000000000000000",  -- ??? (0X1E)
                                "000000000000000000",  -- ??? (0X1F)
                                "000000000000000000",  -- LB (0X20)
                                "000000000000000000",  -- LH (0X21)
                                "000000000000000000",  -- ??? (0X22)
                                "101110111000010101",  -- LW (0X23) ***
                                "000000000000000000",  -- LBU (0X24)
                                "000000000000000000",  -- LHU (0X25)
                                "000000000000000000",  -- LF (0X26)
                                "000000000000000000",  -- LD (0X27)
                                "000000000000000000",  -- SB (0X28)
                                "000000000000000000",  -- SH (0X29)
                                "000000000000000000",  -- ??? (0X2A)
                                "101110111000100100",  -- SW (0X2B) ***
                                "000000000000000000",  -- ??? (0x2C)
                                "000000000000000000",  -- ??? (0x2D)
                                "000000000000000000",  -- SF (0x2E)
                                "000000000000000000",  -- SD (0x2F)
                                "000000000000000000",  -- ??? (0x30)
                                "000000000000000000",  -- ??? (0x31)
                                "000000000000000000",  -- ??? (0x32)
                                "000000000000000000",  -- ??? (0x33)
                                "000000000000000000",  -- ??? (0x34)
                                "000000000000000000",  -- ??? (0x35)
                                "000000000000000000",  -- ??? (0x36)
                                "000000000000000000",  -- ??? (0x37)
                                "000000000000000000",  -- ITLB (0x38)
                                "000000000000000000",  -- ??? (0x39)
                                "101010111000000111",  -- SLTUI (0x3A) @@@
                                "101010111000000111",  -- SGTUI (0x3B) @@@
                                "101010111000000111",  -- SLEUI (0x3C) @@@
                                "101010111000000111"); -- SGEUI (0x3D) @@@

  -- Instructions with "***" will be implemented in the Basic DLX.
  -- Instructions with "@@@" will be implemented in the Pro DLX.
  -- Other unused Control Words must be kept in this memory!
  -- The reason is because the Opcode value is also used to Address its location in the Control Word Memory.

  -- COMMENTED CONTROL WORD MEMORY WITH ONLY THE IMPLEMENTED INSTRUCTIONS, FOR REFERENCE
  -- NOTE: MSB -> LSB
  -- signal cw_mem : mem_array := ("101000101000000111", -- R type (0x00) ***
  --                               "110010011110001100", -- J (0X02) ***
  --                               "110011011110001101", -- JAL (0x03) ***
  --                               "111110011101001100", -- BEQZ (0x04) ***
  --                               "111110011100001100", -- BNEZ (0x05) ***
  --                               "101110111000000111", -- ADD i (0X08) ***
  --                               "101010111000000111", -- ADDUI (0X09) @@@
  --                               "101110111000000111", -- SUBI (0X0A) ***
  --                               "101010111000000111", -- SUBUI (0X0B) @@@
  --                               "101110111000000111", -- ANDI (0X0C) ***
  --                               "101110111000000111", -- ORI (0X0D) ***
  --                               "101110111000000111", -- XORI (0X0E) ***
  --                               "101110111000000111", -- SLLI (0X14) ***
  --                               "100000000000000100", -- NOP (0X15) ***
  --                               "101110111000000111", -- SRLI (0X16) ***
  --                               "101110111000000111", -- SRAI (0X17) @@@
  --                               "101110111000000111", -- SEQI (0X18) @@@
  --                               "101110111000000111", -- SNEI (0X19) ***
  --                               "101110111000000111", -- SLTI (0X1A) @@@
  --                               "101110111000000111", -- SGTI (0X1B) @@@
  --                               "101110111000000111", -- SLEI (0X1C) ***
  --                               "101110111000000111", -- SGEI (0X1D) ***
  --                               "101110111000010101", -- LW (0X23) ***
  --                               "101110111000100100", -- SW (0X2B) ***
  --                               "101010111000000111",-- SLTUI (0x3A) @@@
  --                               "101010111000000111",-- SGTUI (0x3B) @@@
  --                               "101010111000000111",-- SLEUI (0x3C) @@@
  --                               "101010111000000111"); -- SGEUI (0x3D) @@@

  signal IR_opcode : std_logic_vector(OP_CODE_SIZE - 1 downto 0); -- OpCode part of IR
  signal IR_func   : std_logic_vector(FUNC_SIZE - 1 downto 0);    -- Func part of IR when Rtype

  -- Control Word is shifted to the correct stage
  signal cw1 : std_logic_vector(CW_SIZE - 1 downto 0);      -- first stage
  signal cw2 : std_logic_vector(CW_SIZE - 1 - 2 downto 0);  -- second stage
  signal cw3 : std_logic_vector(CW_SIZE - 1 - 6 downto 0);  -- third stage
  signal cw4 : std_logic_vector(CW_SIZE - 1 - 12 downto 0); -- fourth stage
  signal cw5 : std_logic_vector(CW_SIZE - 1 - 16 downto 0); -- fifth stage

  signal aluOpcode_i : aluOp := NOP; -- ALUOP defined in package
  signal aluOpcode1  : aluOp := NOP;
  signal aluOpcode2  : aluOp := NOP;
  signal aluOpcode3  : aluOp := NOP;

begin  -- dlx_cu_rtl

  IR_opcode(5 downto 0) <= IR_IN(31 downto 26);           -- Gets Opcode of Instruction
  IR_func(10 downto 0)  <= IR_IN(FUNC_SIZE - 1 downto 0); -- Gets FUNC Bit Field for R-Type Instructions

  cw1        <= cw_mem(to_integer(unsigned(IR_opcode))); -- Referencing "cw_mem" to get Control Word
  DBG_CW_OUT <= cw1;

  -- stage one control signals
  IR_LATCH_EN  <= cw1(CW_SIZE - 1); -- CW[17]
  NPC_LATCH_EN <= cw1(CW_SIZE - 2); -- CW[16]

  -- stage two control signals
  RegA_LATCH_EN <= cw2(CW_SIZE - 3); -- CW[15]
  -- RegB_LATCH_EN   <= cw2(CW_SIZE - 4); -- CW[14]
  SIGN_UNSIGN_EN  <= cw2(CW_SIZE - 4); -- CW[14]
  RegIMM_LATCH_EN <= cw2(CW_SIZE - 5); -- CW[13]
  JAL_EN          <= cw2(CW_SIZE - 6); -- CW[12]

  -- stage three control signals
  MUXA_SEL      <= cw3(CW_SIZE - 7);  -- CW[11]
  MUXB_SEL      <= cw3(CW_SIZE - 8);  -- CW[10]
  ALU_OUTREG_EN <= cw3(CW_SIZE - 9);  -- CW[9]
  EQ_COND       <= cw3(CW_SIZE - 10); -- CW[8]
  JMP           <= cw3(CW_SIZE - 11); -- CW[7]
  EQZ_NEQZ      <= cw3(CW_SIZE - 12); -- CW[6]

  -- stage four control signals
  DRAM_WE      <= cw4(CW_SIZE - 13); -- CW[5]
  LMD_LATCH_EN <= cw4(CW_SIZE - 14); -- CW[4]
  JUMP_EN      <= cw4(CW_SIZE - 15); -- CW[3]
  PC_LATCH_EN  <= cw4(CW_SIZE - 16); -- CW[2]

  -- stage five control signals
  WB_MUX_SEL <= cw5(CW_SIZE - 17); -- CW[1]
  RF_WE      <= cw5(CW_SIZE - 18); -- CW[0]

  -- process to pipeline control words
  CW_PIPE : process (Clk, nRst) is
  begin                                             -- process Clk

    if (nRst = '0') then                            -- asynchronous reset (active low)
      -- cw1 <= (others => '0');
      cw2        <= (others => '0');
      cw3        <= (others => '0');
      cw4        <= (others => '0');
      cw5        <= (others => '0');
      aluOpcode1 <= NOP;
      aluOpcode2 <= NOP;
    -- aluOpcode3 <= NOP;
    -- elsif Clk'event and Clk = '1' then  -- rising clock edge
    elsif rising_edge(Clk) then
      -- cw1 <= cw;                            -- CW[17:0]
      cw2        <= cw1(CW_SIZE - 1 - 2 downto 0);  -- CW[15:0]
      cw3        <= cw2(CW_SIZE - 1 - 6 downto 0);  -- CW[11:0]
      cw4        <= cw3(CW_SIZE - 1 - 12 downto 0); -- CW[5:0]
      cw5        <= cw4(CW_SIZE - 1 - 16 downto 0); -- CW[1:0]
      aluOpcode1 <= aluOpcode_i;                    -- ALU Opcode created by Control Unit
      aluOpcode2 <= aluOpcode1;
    -- aluOpcode3 <= aluOpcode2; -- ALU Opcode passed to ALU at STAGE 3
    end if;

  end process CW_PIPE;

  ALU_OPCODE <= aluOpcode2; -- ALU Opcode is passed to ALU Block

  -- purpose: Generation of ALU OpCode
  -- type   : combinational
  -- inputs : IR_i
  -- outputs: aluOpcode
  ALU_OP_CODE_P : process (IR_opcode, IR_func) is
  begin                                       -- process ALU_OP_CODE_P

    case to_integer(unsigned(IR_opcode)) is

      -- ALU Opcode for R-Type Instructions when Instruction Opcode is 0x0. Analyze FUNC Bit Field.
      when 0 =>

        case to_integer(unsigned(IR_func)) is
          -- DLX Basic Version
          when 4 => aluOpcode_i <= SLL_op;    -- sll
          when 6 => aluOpcode_i <= SRL_op;    -- srl
          when 32 => aluOpcode_i <= ADD_op;   -- add
          when 34 => aluOpcode_i <= SUB_op;   -- sub
          when 36 => aluOpcode_i <= AND_op;   -- and
          when 37 => aluOpcode_i <= OR_op;    -- or
          when 38 => aluOpcode_i <= XOR_op;   -- xor
          when 41 => aluOpcode_i <= SNE_op;   -- sne
          when 44 => aluOpcode_i <= SLE_op;   -- sle
          when 45 => aluOpcode_i <= SGE_op;   -- sge

          -- DLX Pro Version
          when 7 => aluOpcode_i <= SRA_op;    -- sra
          when 33 => aluOpcode_i <= ADDU_op;  -- addu
          when 35 => aluOpcode_i <= SUBU_op;  -- subu
          when 40 => aluOpcode_i <= SEQ_op;   -- seq
          when 42 => aluOpcode_i <= SLT_op;   -- slt
          when 43 => aluOpcode_i <= SGT_op;   -- sgt
          when 58 => aluOpcode_i <= SLTU_op;  -- sltu
          when 59 => aluOpcode_i <= SGTU_op;  -- sgtu
          when 60 => aluOpcode_i <= SLEU_op;  -- sleu
          when 61 => aluOpcode_i <= SGEU_op;  -- sgeu
          when others => aluOpcode_i <= NOP;

        end case;

      -- ALU Opcode for I-Type & J-Type Instructions when Instruction Opcode != 0x0.
      -- DLX Basic Version
      when 2 => aluOpcode_i <= ADD_op;        -- j
      when 3 => aluOpcode_i <= ADD_op;        -- jal
      when 4 => aluOpcode_i <= ADD_op;        -- beqz
      when 5 => aluOpcode_i <= ADD_op;        -- bnez
      when 8 => aluOpcode_i <= ADD_op;        -- addi
      when 10 => aluOpcode_i <= SUB_op;       -- subi
      when 12 => aluOpcode_i <= AND_op;       -- andi
      when 13 => aluOpcode_i <= OR_op;        -- ori
      when 14 => aluOpcode_i <= XOR_op;       -- xori
      when 20 => aluOpcode_i <= SLL_op;       -- slli
      when 21 => aluOpcode_i <= NOP;          -- nop
      when 22 => aluOpcode_i <= SRL_op;       -- srli
      when 25 => aluOpcode_i <= SNE_op;       -- snei
      when 28 => aluOpcode_i <= SLE_op;       -- slei
      when 29 => aluOpcode_i <= SGE_op;       -- sgei
      when 35 => aluOpcode_i <= ADD_op;       -- lw
      when 43 => aluOpcode_i <= ADD_op;       -- sw

      -- DLX Pro Version
      when 9 => aluOpcode_i <= ADDU_op;       -- addui
      when 11 => aluOpcode_i <= SUBU_op;      -- subui
      when 23 => aluOpcode_i <= SRA_op;       -- srai
      when 24 => aluOpcode_i <= SEQ_op;       -- seqi
      when 26 => aluOpcode_i <= SLT_op;       -- slti
      when 27 => aluOpcode_i <= SGT_op;       -- sgti
      when 58 => aluOpcode_i <= SLTU_op;      -- sltui
      when 59 => aluOpcode_i <= SGTU_op;      -- sgtui
      when 60 => aluOpcode_i <= SLEU_op;      -- sleui
      when 61 => aluOpcode_i <= SGEU_op;      -- sgeui
      when others => aluOpcode_i <= NOP;

    end case;

  end process ALU_OP_CODE_P;

end architecture dlx_cu_hw;
