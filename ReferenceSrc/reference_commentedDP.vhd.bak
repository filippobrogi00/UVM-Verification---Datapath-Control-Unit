-- Libraries copied from a.a-CU_HD.vhd
library ieee;
use ieee.std_logic_1164.all;
use ieee.std_logic_unsigned.all;
use ieee.std_logic_arith.all;
use work.myTypes.all;
use work.rf_pkg.all; -- Needed for "log2()" function. 

entity DATAPATH is
    generic (
        IR_SIZE : INTEGER := 32;            -- Instruction size.
        OPERAND_SIZE : INTEGER := 5;        -- Source / Destination Operand Size
        I_TYPE_IMM_SIZE : INTEGER := 16;    -- Immediate Bit Field Size for I-Type Instruction
        J_TYPE_IMM_SIZE : INTEGER := 26     -- Immediate Bit Field Size for J-Type Instruction
    );
    port(

        -- Other Pins
        CLK                  : IN  std_logic;  -- Clock
        RST                  : IN  std_logic;  -- Reset:Active-Low 
        DP_to_DLX_PC         : OUT std_logic_vector(IR_SIZE - 1 DOWNTO 0); -- Will connect output of S4_MUX_JMP_OUT to PC signal in DLX entity.
        DLX_PC_to_DP         : IN std_logic_vector(IR_SIZE - 1 DOWNTO 0); -- Used to connect PC (Program Counter) from DLX to Adder in Datapath. 
        DLX_IR_to_DP         : IN std_logic_vector(IR_SIZE - 1 DOWNTO 0); -- Used to connect IR (Instruction Register) from DLX to Stage 2 in Datapath. 
        
        -- DRAM Connections 
        DRAM_Addr            : OUT std_logic_vector(IR_SIZE - 1 DOWNTO 0);
        DRAM_DATA            : OUT std_logic_vector(IR_SIZE - 1 DOWNTO 0);
        DRAM_OUT             : IN std_logic_vector(IR_SIZE - 1 DOWNTO 0); 

        --- PIPELINE CONTROL SIGNAL INPUTS ---
        -- Instruction Fetch - STAGE 1
        IR_LATCH_EN          : IN std_logic;
        NPC_LATCH_EN         : IN std_logic;

        -- Instruction Decode - STAGE 2
        RegA_LATCH_EN        : IN std_logic; 
        RegB_LATCH_EN        : IN std_logic;
        RegIMM_LATCH_EN      : IN std_logic;
        JAL_EN               : IN std_logic;

        -- Execute - STAGE 3
        MUX_A_SEL             : IN std_logic;
        MUX_B_SEL             : IN std_logic;
        ALU_OUTREG_EN        : IN std_logic; 
        EQ_COND              : IN std_logic; 
        JMP                  : IN std_logic; 
        EQZ_NEQZ             : IN std_logic; 

        -- ALU Operation Code (STAGE 3) 
        DP_ALU_OPCODE           : IN aluOp; 
    
        -- Memory - STAGE 4
        DRAM_WE              : IN std_logic;  -- Data RAM Write Enable
        LMD_LATCH_EN         : IN std_logic;  -- LMD Register Latch Enable
        JUMP_EN              : IN std_logic;  -- JUMP Enable Signal for PC input MUX
        PC_LATCH_EN          : IN std_logic;  -- Program Counte Latch Enable

        -- Writeback - STAGE 5
        WB_MUX_SEL           : IN std_logic;    -- Write Back MUX Sel
        RF_WE                : IN std_logic);   -- Register File Write Enable
end DATAPATH;

architecture STRUCT_DATAPATH of DATAPATH is

    -- ***********************************************************************
    -- *********************** COMPONENT DECLARATIONS ************************
    -- ***********************************************************************

-- ******************************** ADDER (for PC OFFSET) DECLARATION ********************************
component PC_Adder is
    GENERIC (IR_SIZE: integer := 32);	
	Port (	
    	A			:	IN	std_logic_vector (IR_SIZE - 1 DOWNTO 0);
		Y			: 	OUT	std_logic_vector (IR_SIZE - 1 DOWNTO 0));
end component;

-- ******************************** REGISTER DECLARATION ********************************
component NBit_Reg is
	GENERIC (N: integer := 4); 
	Port (	
		CLK      :	In	std_logic;
		RESET    :	In	std_logic; -- ACTIVE LOW RESET
		LD_EN   : 	IN 	std_logic; 
    	D       :	In	std_logic_vector (N-1 DOWNTO 0);
		Q       :	Out	std_logic_vector (N-1 DOWNTO 0)
  );
end component;

-- ******************************** REGISTER FILE DECLARATION ********************************
component gen_register_file is
    
    generic (
		regBits: integer := 32;
		numRegs: integer := 32); 

    port ( 
	-- INPUTS
	CLK, RESET 			:	IN std_logic; -- ACTIVE LOW RESET!
	ENABLE				: 	IN std_logic;

	-- Read operation
	RD1, RD2 			: 	IN std_logic; -- Read Enable signals
	ADD_RD1, ADD_RD2	: 	IN std_logic_vector(log2(numRegs)-1 downto 0); -- Read Addresses

	-- Write operation
	WR 					: 	IN std_logic; -- Write Enable signal
	ADD_WR 				: 	IN std_logic_vector(log2(numRegs)-1 downto 0); -- Write Address
	DATAIN 				: 	IN std_logic_vector(regBits-1 downto 0); -- Data to write 

	-- OUTPUTS
	OUT1: 		OUT std_logic_vector(regBits-1 downto 0);
	OUT2: 		OUT std_logic_vector(regBits-1 downto 0));
end component;

-- ******************************** SIGNED 16 to 32 EXTENDER DECLARATION ********************************
component sign_extender16_32 is
	GENERIC (N: integer := 16;
			IR_SIZE: integer := 32);

	Port (	
    	IMM_IN  :	In	std_logic_vector (N-1 DOWNTO 0);
		IMM_OUT :	Out	std_logic_vector (IR_SIZE-1 DOWNTO 0));
end component;

-- ******************************** SIGNED 26 to 32 EXTENDER DECLARATION ********************************
component sign_extender26_32 is
	GENERIC (N: integer := 26;
			IR_SIZE: integer := 32);

	Port (	
    	IMM_IN  :	In	std_logic_vector (N-1 DOWNTO 0);
		IMM_OUT :	Out	std_logic_vector (IR_SIZE-1 DOWNTO 0));
end component;

-- ******************************** ZERO COMPARATOR DECLARATION ********************************
component ZeroCompa is
	GENERIC (IR_SIZE: integer := 32);
	Port (	
    	NUMtoCHECK  :	IN	std_logic_vector (IR_SIZE-1 DOWNTO 0);
		EQZ			: 	IN 	std_logic;								-- EQZ = 1 -> Checks if input is equal to '0'; EQZ = 0 -> Checks if input is not equal to '0'. 
		JMP			: 	IN 	std_logic; 
		RESULT 		:	OUT	std_logic);
end component;

-- ******************************** MUX DECLARATION ********************************
component NBit_2to1MUX is
  generic (N : integer := 1);
  port (
    A, B : in std_logic_vector(N-1 downto 0);
    S    : in std_logic;
    Y    : out std_logic_vector(N-1 downto 0));
end component;

-- ******************************** ALU DECLARATION ********************************
component ALU is
	GENERIC (IR_SIZE: integer := 32);
	Port (	
    	A			:	IN	std_logic_vector (IR_SIZE-1 DOWNTO 0);
		B			: 	IN 	std_logic_vector (IR_SIZE-1 DOWNTO 0);
		ALU_OPCODE	: 	IN  aluOp;
		Y			: 	OUT	std_logic_vector (IR_SIZE-1 DOWNTO 0));
end component;

    -- ******************************** STAGE 1 SIGNALS ********************************
    SIGNAL S1_ADD_OUT                     :   std_logic_vector(IR_SIZE - 1 DOWNTO 0);           -- Read as "Output of Stage 1 adder."
    SIGNAL S1_REG_IR_OUT                  :   std_logic_vector(IR_SIZE - 1 DOWNTO 0);           -- Read as "Output of Stage 1 Register named "IR"."
    SIGNAL S1_REG_NPC_OUT                 :   std_logic_vector(IR_SIZE - 1 DOWNTO 0);           -- Read as "Output of Stage 1 Register named "NPC."
    
    -- ******************************** STAGE 2 SIGNALS ********************************
    SIGNAL S2_SE16_OUT                      :   std_logic_vector(IR_SIZE - 1 DOWNTO 0);    -- SE16 = Sign Extender w/16-bit input. 
    SIGNAL S2_SE26_OUT                      :   std_logic_vector(IR_SIZE - 1 DOWNTO 0);    -- SE26 = Sign Extender w/26-bit input.
    SIGNAL S2_REG_SE_IMM_OUT              :   std_logic_vector(IR_SIZE - 1 DOWNTO 0);                  
    SIGNAL S2_REG_UE_IMM_OUT              :   std_logic_vector(IR_SIZE - 1 DOWNTO 0);       
    SIGNAL S2_RFILE_A_OUT                 :   std_logic_vector(IR_SIZE - 1 DOWNTO 0);      -- RFILE = Register File
    SIGNAL S2_RFILE_B_OUT                 :   std_logic_vector(IR_SIZE - 1 DOWNTO 0);      
    SIGNAL S2_REG_A_OUT                   :   std_logic_vector(IR_SIZE - 1 DOWNTO 0);            
    SIGNAL S2_REG_B_OUT                   :   std_logic_vector(IR_SIZE - 1 DOWNTO 0);           
    SIGNAL S2_FF_JAL_EN_OUT               :   std_logic;                                    -- Part of sequence of Flip-Flops which connect to the select signal of the MUX in Stage 5.
    SIGNAL S2_MUX_ADD_WR_OUT              :   std_logic_vector(OPERAND_SIZE - 1 DOWNTO 0);  -- Part of sequence of registers at Write-Address input of Register File.
    SIGNAL S2_MUX_IorR_OUT                :   std_logic_vector(OPERAND_SIZE - 1 DOWNTO 0);  -- To select correct bits from either R-Type or I-Type Instruction.
    SIGNAL S2_REG_ADD_WR_OUT              :   std_logic_vector(OPERAND_SIZE - 1 DOWNTO 0);  -- Part of sequence of registers at Write-Address input of Register File.
    SIGNAL S2_REG_NPC_OUT                 :   std_logic_vector(IR_SIZE - 1 DOWNTO 0); 


    -- ******************************** STAGE 3 SIGNALS ********************************
    SIGNAL S3_BranchTaken                 :   std_logic;   
    SIGNAL S3_MUX_A_OUT                   :   std_logic_vector(IR_SIZE - 1 DOWNTO 0);   
    SIGNAL S3_MUX_B_OUT                   :   std_logic_vector(IR_SIZE - 1 DOWNTO 0);  
    SIGNAL S3_ALU_OUT                     :   std_logic_vector(IR_SIZE - 1 DOWNTO 0);            
    SIGNAL S3_MUX_JMP_OUT                 :   std_logic_vector(IR_SIZE - 1 DOWNTO 0);   
    SIGNAL S3_REG_ALU_OUT                 :   std_logic_vector(IR_SIZE - 1 DOWNTO 0);       
    SIGNAL S3_FF_COND_OUT                 :   std_logic;    
    SIGNAL S3_REG_DATA_OUT                :   std_logic_vector(IR_SIZE - 1 DOWNTO 0);  
    SIGNAL S3_FF_JAL_EN_OUT               :   std_logic;                     -- Part of sequence of Flip-Flops which connect to the select signal of the MUX in Stage 5.
    SIGNAL S3_REG_ADD_WR_OUT              :   std_logic_vector(4 DOWNTO 0);  
    SIGNAL S3_REG_NPC_OUT                 :   std_logic_vector(IR_SIZE - 1 DOWNTO 0); 
    
    
    -- ******************************** STAGE 4 SIGNALS ********************************
    SIGNAL S4_AND_OUT                     :   std_logic;  
    SIGNAL S4_REG_LMD_OUT                 :   std_logic_vector(IR_SIZE - 1 DOWNTO 0);    
    SIGNAL S4_REG_ALU_OUT                 :   std_logic_vector(IR_SIZE - 1 DOWNTO 0); 
    SIGNAL S4_MUX_JMP_OUT                 :   std_logic_vector(IR_SIZE - 1 DOWNTO 0); 
    SIGNAL S4_FF_JAL_EN_OUT               :   std_logic;                     -- Part of sequence of Flip-Flops which connect to the select signal of the MUX in Stage 5.  
    SIGNAL S4_REG_ADD_WR_OUT              :   std_logic_vector(4 DOWNTO 0);  -- Part of sequence of registers at Write-Address input of Register File.
    SIGNAL S4_REG_NPC_OUT                 :   std_logic_vector(IR_SIZE - 1 DOWNTO 0); 
    SIGNAL S4_MUX_JMP_SEL                 :   std_logic;


    -- ******************************** STAGE 5 SIGNALS ********************************
    SIGNAL S5_MUX_DATAIN_OUT              :   std_logic_vector(IR_SIZE - 1 DOWNTO 0); 
    SIGNAL S5_MUX_WB_OUT                  :   std_logic_vector(IR_SIZE - 1 DOWNTO 0); 
    
begin  

    -- ****************************************************************************************
    -- ******************************** STAGE 1 INSTANTIATIONS ********************************
    -- ****************************************************************************************
    
    S1_REG_IR_OUT <= DLX_IR_to_DP;          -- Connects DLX Entity's Instruction Register (DLX_IR_to_DP) value to the Datapath (S1_REG_IR_OUT). 

    -- Increments by 4 the PC 
    S1_ADD : PC_Adder
        generic map (
            IR_SIZE => IR_SIZE)
        port map (
            A => DLX_PC_to_DP,
            Y => S1_ADD_OUT);

    -- Delays PC so that it becomes NPC 
    S1_REG_NPC: NBit_Reg
      generic map (
            N => IR_SIZE)
        port map (
          CLK    => CLK,
          RESET  => RST,
          LD_EN  => NPC_LATCH_EN,
          D  => S1_ADD_OUT,
          Q  => S1_REG_NPC_OUT);  
    
    -- ****************************************************************************************
    -- ******************************** STAGE 2 INSTANTIATIONS ********************************
    -- ****************************************************************************************

    -- Selects parts of instruction opcode
    S2_MUX_IorR : NBit_2to1MUX
        generic map (
            N => OPERAND_SIZE
        )
        port map (
            A => S1_REG_IR_OUT(20 DOWNTO 16), -- I-TYPE (RD)          // R-TYPE (RS2)  
            B => S1_REG_IR_OUT(15 DOWNTO 11), -- I-TYPE (part of IMM) // R-TYPE (RD)
            S => RegIMM_LATCH_EN,             -- 1 -> A, 0 -> B
            Y => S2_MUX_IorR_OUT              -- [ I-TYPE (RD) // R-TYPE (RS2) ]
                                              -- // 
                                              -- [ I-TYPE (part of IMM) // R-TYPE (RD) ]
        );

    -- Selects Register 31, LR, (if needing to perform JAL) or the result of above MUX 
    S2_MUX_ADD_WR : NBit_2to1MUX
        generic map (
            N => OPERAND_SIZE
        )
        port map (
            A => "11111",           -- 31st Register of Register File. Used for JAL Instruction.
            B => S2_MUX_IorR_OUT,
            S => JAL_EN,
            Y => S2_MUX_ADD_WR_OUT            -- LR's RF address
                                              -- // 
                                              -- {
                                                -- [ I-TYPE (RD) // R-TYPE (RS2) ]
                                                -- // 
                                                -- [ I-TYPE (part of IMM) // R-TYPE (RD) ]
                                              -- }

        );        

    -- Delays the result of above MUX by 1 CC 
    -- LR // I-TYPE(RD) // R-TYPE(RS2) // I-TYPE(part of IMM) // R-TYPE(RD)
    S2_REG_ADD_WR: NBit_Reg
        generic map (
            N => OPERAND_SIZE
        )
        port map (
            CLK => CLK,
            RESET => RST,
            LD_EN  => '1',
            D   => S2_MUX_ADD_WR_OUT,
            Q   => S2_REG_ADD_WR_OUT            
        );

    -- Register File 
    -- Writes DATAIN (NPC // ALU_OUT // DRAM_OUT) 
    -- to ( LR // I-TYPE(RD) // R-TYPE(RS2) // I-TYPE(part of IMM) // R-TYPE(RD) ):
    --    LR                    if doing JAL op    (write NPC)                               // 
    --    I-TYPE(RD)            if doing I-TYPE op (write ALU_OUT // DRAM_OUT if doing LW)   // 
    --    R-TYPE(RS2)           if doing none ???                                            // 
    --    I-TYPE(part of IMM)   if doing none ???                                            //
    --    R-TYPE(RD)            if doing R-TYPE op 

    -- Outputs (read): 
    --    RFILE[RS1]          on port 1 if doing I-TYPE or R-TYPE op // 
    --    RFILE[I-TYPE (RD)]  on port 2 if doing I-TYPE op           // 
    --    RFILE[R-TYPE (RS2)] on port 2 if doing R-TYPE op 
    -- Possible outputs: 
    --    PORT 1       |     PORT 2  
    --  --------------------------------
    --   RFILE[RS1]    |  RFILE[RD]
    --   RFILE[RS1]    |  RFILE[RS2]
    S2_RFILE : gen_register_file
        generic map (
            regBits => IR_SIZE,
            numRegs => 32
        )
        port map (
            CLK   => CLK,
            RESET => RST,
            ENABLE => '1', 
            RD1 => '1', 
            RD2 => '1', 
            ADD_RD1 => S1_REG_IR_OUT(25 DOWNTO 21), -- RS1 for both I-TYPE and R-TYPE 
            ADD_RD2 => S1_REG_IR_OUT(20 DOWNTO 16), -- I-TYPE (RD) // R-TYPE (RS2)
            WR => RF_WE, 
            ADD_WR => S4_REG_ADD_WR_OUT,            -- S2_MUX_ADD_WR output delayed by 2 CCs
            DATAIN => S5_MUX_DATAIN_OUT,            -- delayed NPC // delayed ALU out // delayed DRAM out  
            OUT1 => S2_RFILE_A_OUT,                 -- RFILE[RS1]
            OUT2 => S2_RFILE_B_OUT                  -- RFILE[I-TYPE (RD)] // RFILE[R-TYPE (RS2)]
        );

    -- Sign-extends I-TYPE (IMM) to 32 bits  
    S2_SE16 : sign_extender16_32
        generic map (
            IR_SIZE => IR_SIZE
        )
        port map (
            IMM_IN => S1_REG_IR_OUT(15 DOWNTO 0),
            IMM_OUT => S2_SE16_OUT            
        );

    -- Sign-extends J-TYPE (IMM) to 32 bits 
    S2_SE26 : sign_extender26_32
        generic map (
            IR_SIZE => IR_SIZE
        )
        port map (
            IMM_IN => S1_REG_IR_OUT(25 DOWNTO 0),
            IMM_OUT => S2_SE26_OUT
        );

    -- Delays by 1 CC the output of the 16-32 sign-extender 
    S2_REG_SE16_IMM : NBit_Reg
        generic map (
            N => IR_SIZE
        )
        port map (
            CLK => CLK,
            RESET => RST,
            LD_EN  => RegIMM_LATCH_EN,
            D   => S2_SE16_OUT,
            Q   => S2_REG_SE_IMM_OUT
        );

    -- Delays by 1 CC the output of the 26-32 sign-extender 
    S2_REG_SE26_IMM : NBit_Reg
        generic map (
            N => IR_SIZE
        )
        port map (
            CLK => CLK,
            RESET => RST,
            LD_EN  => RegIMM_LATCH_EN,
            D   => S2_SE26_OUT,
            Q   => S2_REG_UE_IMM_OUT
        );

    -- Delays by 1 CC the JAL_EN signal 
    S2_FF_JAL_EN : NBit_Reg
        generic map (
            N => 1
        )
        port map (
            CLK => CLK,
            RESET => RST,
            LD_EN  => '1',
            D(0)   => JAL_EN,
            Q(0)   => S2_FF_JAL_EN_OUT
        );

    -- Delays by 1 CC the NPC signal 
    S2_REG_NPC : NBit_Reg
        generic map (
            N => IR_SIZE
        )
        port map (
            CLK => CLK,
            RESET => RST,
            LD_EN  => '1',
            D   => S1_REG_NPC_OUT,
            Q   => S2_REG_NPC_OUT
        );
    
    -- ****************************************************************************************
    -- ******************************** STAGE 3 INSTANTIATIONS ********************************
    -- ****************************************************************************************

    -- Selects contents of address RS1 inside RFILE or NPC 
    S3_MUX_A : NBit_2to1MUX
        generic map (
            N => IR_SIZE
        )
        port map (
            A => S2_RFILE_A_OUT, -- RFILE[RS1]
            B => S1_REG_NPC_OUT, -- NPC 
            S => MUX_A_SEL,
            Y => S3_MUX_A_OUT    -- RFILE[RS1] // NPC  
        );
        
    -- Selects Immediate fields (extended on 32 bits) or contents of RF (see MUX below)
    S3_MUX_B : NBit_2to1MUX
        generic map (
            N => IR_SIZE
        )
        port map (
            A => S3_MUX_JMP_OUT, -- (R-TYPE (IMM) ## 32) // (I-TYPE (IMM) ## 32) see mux below 
            B => S2_RFILE_B_OUT, -- RFILE[I-TYPE (RD)] // RFILE[R-TYPE (RS2)]
            S => MUX_B_SEL,
            Y => S3_MUX_B_OUT    -- [ (R-TYPE (IMM) ## 32) // (I-TYPE (IMM) ## 32) ]  
                                 -- // 
                                 -- [  RFILE[I-TYPE (RD)] // RFILE[R-TYPE (RS2)] ]
        ); 

    -- Selects (R-TYPE (IMM) ## 32) if we need to JMP, otherwise (I-TYPE (IMM) ## 32)
    S3_MUX_JMP : NBit_2to1MUX
        generic map (
            N => IR_SIZE
        )
        port map (
            A => S2_REG_UE_IMM_OUT, -- 26->32 sign extender output (delayed)
            B => S2_REG_SE_IMM_OUT, -- 16->32 sign extender output (delayed)
            S => JMP,
            Y => S3_MUX_JMP_OUT          
        ); 

    -- Performs an operation on its operands 
    -- Possible operations: 
    --  RFILE[RS1] OP ( R-TYPE (IMM) ## 32 )   {I1} calculating result to store into RD for R-TYPE ops 
    --  RFILE[RS1] OP ( I-TYPE (IMM) ## 32 )   {R1} calculating part of result for I-TYPE ops
    --  RFILE[RS1] OP ( RFILE[I-TYPE (RD)] )   ???  result will be written in RF from S5 later on 
    --  RFILE[RS1] OP ( RFILE[R-TYPE (RS2)] )  {R2} calculating remaining part of result to store into RD for R-TYPE ops 
    --  NPC        OP ( R-TYPE (IMM) ## 32 )   ??? no jumps in R-TYPE ops  
    --  NPC        OP ( I-TYPE (IMM) ## 32 )   when performing B(N)EQZ, do NPC + offset_to_label_IMM   
    --  NPC        OP ( RFILE[I-TYPE (RD)] )   ???  
    --  NPC        OP ( RFILE[R-TYPE (RS2)] )  ??? 
    S3_ALU : ALU
        generic map (
            IR_SIZE => IR_SIZE
        )
        port map (
            A => S3_MUX_A_OUT,
            B => S3_MUX_B_OUT,
            ALU_OPCODE => DP_ALU_OPCODE,
            Y => S3_ALU_OUT
        );
    
    -- Delays ALU output by 1 CC  (also called ALU_OUTREG)
    S3_REG_ALU : NBit_Reg
        generic map (
            N => IR_SIZE
        )
        port map (
            CLK => CLK,
            RESET => RST,
            LD_EN  => ALU_OUTREG_EN,
            D   => S3_ALU_OUT,
            Q   => S3_REG_ALU_OUT
        );

    -- Delays by 1 CC RFILE B output 
    S3_REG_DATA : NBit_Reg
        generic map (
            N => IR_SIZE
        )
        port map (
            CLK => CLK,
            RESET => RST,
            LD_EN  => '1',
            D   => S2_RFILE_B_OUT, -- RFILE[I-TYPE (RD)] // RFILE[R-TYPE (RS2)]
            Q   => S3_REG_DATA_OUT
        );

    -- Delays by 1 CC the Zero Comparator output (S3_BranchTaken)  (see ZeroCompa below)
    S3_REG_COND : NBit_Reg
        generic map (
            N => 1
        )
        port map (
            CLK => CLK,
            RESET => RST,
            LD_EN  => EQ_COND,
            D(0)   => S3_BranchTaken,
            Q(0)   => S3_FF_COND_OUT
        );

    -- When doing a B(N)EQZ (I-TYPE), compares RFILE[RS1] to zero 
    -- e.g. BEQZ R2, target_label    # here R2 is RFILE[RS1]
    S3_ZeroCompa: ZeroCompa
        generic map (
            IR_SIZE => IR_SIZE
        )
        port map (
            NUMtoCHECK => S2_RFILE_A_OUT, -- RFILE[RS1]
            EQZ => EQZ_NEQZ,              -- From CU ?
            JMP => JMP,
            RESULT => S3_BranchTaken            
        );

    -- Delays by 2 CCs the original JAL_EN signal 
    S3_FF_JAL_EN : NBit_Reg
        generic map (
            N => 1
        )
        port map (
            CLK => CLK,
            RESET => RST,
            LD_EN  => '1',
            D(0)   => S2_FF_JAL_EN_OUT,
            Q(0)   => S3_FF_JAL_EN_OUT
        );

    -- Delays by 2 CCs the original NPC signal 
    S3_REG_NPC : NBit_Reg
        generic map (
            N => IR_SIZE
        )
        port map (
            CLK => CLK,
            RESET => RST,
            LD_EN  => '1',
            D   => S2_REG_NPC_OUT,
            Q   => S3_REG_NPC_OUT
        );
        
     -- Delays by 2 CCs the original S2_MUX_ADD_WR_OUT signal 
     -- LR // I-TYPE(RD) // R-TYPE(RS2) // I-TYPE(part of IMM) // R-TYPE(RD)
     S3_REG_ADD_WR : NBit_Reg
        generic map (
            N => OPERAND_SIZE
        )
        port map (
            CLK => CLK,
            RESET => RST,
            LD_EN  => '1',
            D   => S2_REG_ADD_WR_OUT,
            Q   => S3_REG_ADD_WR_OUT
        );

    -- ****************************************************************************************
    -- ******************************** STAGE 4 INSTANTIATIONS ********************************
    -- ****************************************************************************************

    -- why needed ?
    DRAM_Addr <= S3_REG_ALU_OUT;            -- Connects Datapath's Stage 3 Register called "ALU_OUT" to Address input of the DRAM. 
    DRAM_DATA <= S3_REG_DATA_OUT;           -- Connects Datapath's Stage 3 Register called "DATA_OUT" to Data input of the DRAM.

    -- JUMP_EN input, S3_FF_COND_OUT is S3_BranchTaken delayed by 1 CC 
    -- It's the Stage4 AND port which takes the current jmp signal sent from the 
    -- CU and the previous Decode-Stage calculated jump condition 
    S4_MUX_JMP_SEL <= ((S3_FF_COND_OUT) AND (JUMP_EN));

    -- Selects ALU output (if JMP instruction) or NPC signal when no JMP instruction
    S4_MUX_JMP : NBit_2to1MUX
        generic map (
            N => IR_SIZE
        )
        port map (
            A => S3_REG_ALU_OUT, -- ALU output delayed by 1 CC 
            B => S1_ADD_OUT,     -- NPC signal before any delays 
            S => S4_MUX_JMP_SEL, 
            Y => DP_to_DLX_PC
        );

    -- Delays by 1 CC the DRAM's output
    S4_REG_LMD : NBit_Reg
        generic map (
            N => IR_SIZE
        )
        port map (
            CLK => CLK,
            RESET => RST,
            LD_EN  => LMD_LATCH_EN,
            D   => DRAM_OUT,
            Q   => S4_REG_LMD_OUT
        );

    -- Delays by 2 CCs the ALU output 
    S4_REG_ALU : NBit_Reg
        generic map (
            N => IR_SIZE
        )
        port map (
            CLK => CLK,
            RESET => RST,
            LD_EN  => '1',
            D   => S3_REG_ALU_OUT,
            Q   => S4_REG_ALU_OUT
        );       

    -- Delays by 3 CCs the original JAL_EN signal
    S4_FF_JAL_EN : NBit_Reg
        generic map (
            N => 1
        )
        port map (
            CLK => CLK,
            RESET => RST,
            LD_EN  => '1',
            D(0)   => S3_FF_JAL_EN_OUT,
            Q(0)   => S4_FF_JAL_EN_OUT
        );

    -- Delays by 3 CCs the original NPC signal
    S4_REG_NPC : NBit_Reg
        generic map (
            N => IR_SIZE
        )
        port map (
            CLK => CLK,
            RESET => RST,
            LD_EN  => '1',
            D   => S3_REG_NPC_OUT,
            Q   => S4_REG_NPC_OUT
        );
        
    -- Delays by 3 CCs the original S2_MUX_ADD_WR_OUT signal 
    -- LR // I-TYPE(RD) // R-TYPE(RS2) // I-TYPE(part of IMM) // R-TYPE(RD)
    S4_REG_ADD_WR : NBit_Reg
        generic map (
            N => OPERAND_SIZE
        )
        port map (
            CLK => CLK,
            RESET => RST,
            LD_EN  => '1',
            D   => S3_REG_ADD_WR_OUT,
            Q   => S4_REG_ADD_WR_OUT
        );

    -- ****************************************************************************************
    -- ******************************** STAGE 5 INSTANTIATIONS ********************************
    -- ****************************************************************************************

    -- Selects ALU out delayed by 2 CCs or DRAM out delayed by 1 (so they are synchronized)
    S5_MUX_WB : NBit_2to1MUX
        generic map (
            N => IR_SIZE
        )
        port map (
            A => S4_REG_ALU_OUT, -- ALU output delayed by 2 CCs 
            B => S4_REG_LMD_OUT, -- DRAM's output register 
            S => WB_MUX_SEL,
            Y => S5_MUX_WB_OUT
        );

    -- Selects NPC, ALU output, or DRAM output signal to feed back to RFILE 
    S5_MUX_DATAIN : NBit_2to1MUX
        generic map (
            N => IR_SIZE
        )
        port map (
            A => S4_REG_NPC_OUT,   -- NPC signal delayed by 3 CCs 
            B => S5_MUX_WB_OUT,    -- ALU out delayed by 2 CCs // DRAM out delayed by 1 CC    
            S => S4_FF_JAL_EN_OUT,
            Y => S5_MUX_DATAIN_OUT -- delayed NPC      (if doing JAL)    //
                                   -- delayed ALU out  (if R/I-TYPE ops) // 
                                   -- delayed DRAM out (if LW op)
        );
    
        
end STRUCT_DATAPATH;
